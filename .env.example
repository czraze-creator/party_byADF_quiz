# =====================================================================
# Party byADF Quiz — environment variables
# Copy to .env.local for development. In production set in Vercel / host.
# =====================================================================

# Admin password — used to log into /admin
# CHANGE THIS BEFORE DEPLOY.
ADMIN_PASSWORD=adf2026

# ---------------------------------------------------------------------
# Supabase (required — data store)
# ---------------------------------------------------------------------
# Dashboard → Project Settings → API
#   NEXT_PUBLIC_SUPABASE_URL      = Project URL  (https://xxxx.supabase.co)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = anon / public key  (currently unused, prepared for browser-side reads)
#   SUPABASE_SERVICE_ROLE_KEY     = service_role key  (server-side, bypasses RLS — NEVER expose to client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
